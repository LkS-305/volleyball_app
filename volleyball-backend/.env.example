# Copy to `.env` and fill in. `.env` is gitignored — never commit real values.
# Load it however you like, e.g.:  set -a; . ./.env; set +a; go run .

# Which backend to use: "json" (local file, zero setup) or "sheets" (Google Sheets).
STORE_BACKEND=json

# --- JSON backend ----------------------------------------------------------
# Path to the local JSON file (only used when STORE_BACKEND=json).
JSON_STORE_PATH=data/sessions.json

# --- Google Sheets backend -------------------------------------------------
# Path to the service-account JSON key file. NEVER commit this file.
GOOGLE_SHEETS_CREDENTIALS_PATH=./service-account.json
# The spreadsheet id — the long token in the URL between /d/ and /edit:
#   https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# HTTP port (optional, default 8080)
PORT=8080
